# Bind only to loopback for a bare-metal systemd deployment.
INTENT_CLASSIFIER_HOST=127.0.0.1
INTENT_CLASSIFIER_PORT=18080
INTENT_CLASSIFIER_MODEL_ROOT=/var/lib/sub2api/intent-models
INTENT_CLASSIFIER_STATE_DIR=/var/lib/sub2api/intent-classifier-state

# Leave empty to restore the active version from persistent state.
INTENT_CLASSIFIER_ACTIVE_VERSION=
INTENT_CLASSIFIER_MODEL_VERSION=

# Set independent random values before starting the service.
INTENT_CLASSIFIER_API_TOKEN=
INTENT_CLASSIFIER_ADMIN_TOKEN=

INTENT_CLASSIFIER_MAX_CONCURRENCY=4
INTENT_CLASSIFIER_MAX_REQUEST_BYTES=65536
INTENT_CLASSIFIER_INFERENCE_TIMEOUT_MS=250
INTENT_CLASSIFIER_LOG_LEVEL=INFO
INTENT_CLASSIFIER_ADMIN_URL=http://127.0.0.1:18080
